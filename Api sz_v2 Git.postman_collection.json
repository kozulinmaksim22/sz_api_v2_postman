  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// Получаем значение server_key из переменных коллекции\r",
          "let serverKey = pm.collectionVariables.get(\"Serverkey\");\r",
          "\r",
          "// Проверяем что ключ существует\r",
          "if (serverKey) {\r",
          "\r",
          "    // Добавляем заголовок к запросу\r",
          "    pm.request.headers.upsert({\r",
          "        key: \"server_key\",\r",
          "        value: serverKey\r",
          "    });\r",
          "\r",
          "} else {\r",
          "\r",
          "    console.log(\"Переменная server_key не найдена в коллекции\");\r",
          "\r",
          "}\r",
          "\r",
          "// Пути для в которые не нужно вставлять Authorization\r",
          "const excludedPaths = [\r",
          "    \"/auth/login\",\r",
          "    \"/auth/refresh\",\r",
          "    \"/public/ping\"\r",
          "];\r",
          "// получаем путь текущего запроса\r",
          "let path = pm.request.url.getPath();\r",
          "// проверяем, попадает ли путь в исключения\r",
          "let isExcluded = excludedPaths.some(p => path.startsWith(p));\r",
          "// Получаем значение JWT из переменных коллекции\r",
          "let JWT = \"BEARER \" + pm.collectionVariables.get(\"JWT\");\r",
          "\r",
          "if (!isExcluded) {\r",
          "    // Проверяем что ключ существует\r",
          "    if (JWT) {\r",
          "\r",
          "        // Добавляем заголовок к запросу\r",
          "        pm.request.headers.upsert({\r",
          "            key: \"Authorization\",\r",
          "            value: JWT\r",
          "        });\r",
          "\r",
          "    } else {\r",
          "\r",
          "        console.log(\"Переменная JWT не найдена в коллекции\");\r",
          "\r",
          "    }\r",
          "\r",
          "} else {\r",
          "\r",
          "    console.log(\"Authorization пропущен для пути: \" + path);\r",
          "\r",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// Получаем значение заголовка x_user\r",
          "let jwtToken = pm.response.headers.get(\"x_user\");\r",
          "\r",
          "// Проверяем наличие заголовка\r",
          "if (jwtToken) {\r",
          "\r",
          "    // Сохраняем в переменную коллекции\r",
          "    pm.collectionVariables.set(\"JWT\", jwtToken);\r",
          "\r",
          "    console.log(\"JWT успешно сохранён в переменную коллекции\");\r",
          "\r",
          "}"
        ]
      }
    }
